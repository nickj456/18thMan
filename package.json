{
  "name": "18thman-match-analyst",
  "version": "1.7.17",
  "description": "18thMan Match Analyst — video analysis for rugby league coaches",
  "main": "src/main/main.js",
  "scripts": {
    "dev": "concurrently \"npm run dev:react\" \"npm run dev:electron\"",
    "dev:react": "vite",
    "dev:electron": "wait-on http://localhost:5173 && node scripts/dev-electron.js",
    "build:react": "vite build",
    "build": "npm run build:react && electron-builder",
    "package": "npm run build"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.3.1",
    "concurrently": "^9.1.0",
    "cross-env": "^7.0.3",
    "electron": "^33.4.11",
    "electron-builder": "^25.1.8",
    "vite": "^6.0.3",
    "wait-on": "^8.0.1"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.105.4",
    "electron-store": "^8.1.0",
    "electron-updater": "^6.8.3",
    "ffmpeg-static": "4.4.1",
    "fluent-ffmpeg": "^2.1.3",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  }
}
